<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Chassis dimensions in meters -->
    <xacro:property name="shaft_length" value="0.127"/>  <!-- 5 inches -->
    <xacro:property name="shaft_width" value="0.08382"/>    <!-- 3.3 inches -->
    <xacro:property name="shaft_height" value="0.05334"/>  <!-- 2.1 inches -->
    <xacro:property name="shaft_mass" value="0.6"/>   <!-- 0.6 kg, adjust as needed -->

    <!-- Fixed mount point that connects to your arm's end link -->

    <xacro:macro name="shaft_motor" params="parent *origin">

    <link name="shaft_link">
        <!-- Visual representation -->
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${shaft_length} ${shaft_width} ${shaft_height}"/>
            </geometry>
            <material name="soft_purple">
                <color rgba="0.7 0.4 0.9 1.0"/>
            </material>
        </visual>

        <!-- Collision representation -->
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${shaft_length} ${shaft_width} ${shaft_height}"/>
            </geometry>
        </collision>

        <!-- Inertial properties -->
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${shaft_mass}"/>
            <inertia
                ixx="${(1/12) * shaft_mass * (shaft_width*shaft_width + shaft_height*shaft_height)}"
                ixy="0.0"
                ixz="0.0"
                iyy="${(1/12) * shaft_mass * (shaft_length*shaft_length + shaft_height*shaft_height)}"
                iyz="0.0"
                izz="${(1/12) * shaft_mass * (shaft_length*shaft_length + shaft_width*shaft_width)}"/>
        </inertial>
    </link>

        <!-- Flip joint: rotates around X axis (shaft's long axis) -->
    <joint name="tool_flip_joint" type="revolute">
        <parent link="base_link"/>
        <child link="shaft_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>  <!-- rotate along shaft length -->
        <limit lower="0.0" upper="3.1416" effort="10.0" velocity="1.0"/>
    </joint>

    <!-- Claw side: positive X end of shaft -->
    <link name="claw_mount_link"/>
    <joint name="shaft_to_claw" type="fixed">
        <parent link="shaft_link"/>
        <child link="claw_mount_link"/>
        <origin xyz="${shaft_length/2} 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Drill side: negative X end of shaft -->
    <link name="drill_mount_link"/>
    <joint name="shaft_to_drill" type="fixed">
        <parent link="shaft_link"/>
        <child link="drill_mount_link"/>
        <origin xyz="${-shaft_length/2} 0 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="shaft_link">
        <visual>
            <material>
                <ambient>0.7 0.4 0.9 1.0</ambient>
                <diffuse>0.7 0.4 0.9 1.0</diffuse>
                <specular>0.8 0.8 0.8 1.0</specular>
            </material>
        </visual>
    </gazebo>







    </xacro:macro>


</robot>


<!-- 
- motor of claw so parent link is the last join kaitlyn creates
    -  parent link to the actual claw
    - parent link to the drill bit 
    - how do we represent motors and movements 
    - plug it into a gazebo harmonic diff drive plugin -->